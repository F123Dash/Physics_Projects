.venv
/.vscode
__pycache__

# Ignore common executable outputs anywhere in the repo
**/*.exe
**/*.out
**/*.bin
**/*.app

# Ignore extensionless binaries from C/C++ builds (e.g. 1D, 2D, 3D)
**/results_outputs/*
**/1D
**/2D
**/3D

# Ignore generated data files and folders
**/data/
**/data_*/
**/data_outputs/
**/*.csv
**/*.tsv
**/*.dat
**/*.npy
**/*.npz
**/*.h5
**/*.hdf5

# Ignore generated plot files and folders
**/plot/
**/plots/
**/plot_outputs/
**/*.png
**/*.jpg
**/*.jpeg
**/*.svg
**/*.pdf